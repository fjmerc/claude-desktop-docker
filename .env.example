# Optional environment variables for claude-desktop-docker.
# Copy to .env (untracked) to override defaults without editing docker-compose.yml.

# VNC password. If empty/unset, a random one is generated on first start
# and printed to `docker logs claude-desktop`. Set to a fixed value to
# avoid the log scrape.
VNC_PASSWORD=

# Host port mappings. Change these only if 5901/6080 collide with
# something else on your host.
VNC_PORT=5901
NOVNC_PORT=6080

# Kiosk mode: when "true", swap the XFCE panel/desktop for a minimal
# openbox session running just Claude. No taskbar, no file manager,
# borderless full-screen Claude. Super+Space relaunches if you close it.
# Default (unset/false) is full XFCE — best for MCP server management
# from the file manager / terminal.
KIOSK_MODE=
