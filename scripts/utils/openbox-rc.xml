<?xml version="1.0" encoding="UTF-8"?>
<!--
  Minimal openbox config for KIOSK_MODE.
  Used by xstartup-kiosk, which copies this file to ~/.config/openbox/rc.xml.

  - No panel, no taskbar — root window is the only thing on screen.
  - Claude window opens borderless and maximized (see <applications>).
  - Super+Space relaunches Claude if you accidentally close it.
-->
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <focus>
    <focusNew>yes</focusNew>
  </focus>

  <placement>
    <policy>UnderMouse</policy>
  </placement>

  <keyboard>
    <!-- Super+C: relaunch Claude. Hard-won details, do not "simplify":
         * The key must be a letter. "space" bound with any modifier never
           fires on this Xvnc/XKB setup (verified with xdotool tracers:
           C-A-y and C-A-c fire, C-A-space and W-space never do).
         * The command is fully explicit: openbox's environment only has
           DISPLAY, and the launcher in the claude_app volume may predate
           root/sandbox auto-detection (the volume shadows newer image
           content), so it needs both ELECTRON_* vars and the sandbox flag.
         * Don't shorten it to a bare "claude-desktop":
           /usr/local/bin/claude-desktop is a copied (not symlinked)
           launcher that resolves its app dir relative to itself and dies
           looking for /usr/local/lib/claude-desktop/app.asar.
         * Never write a literal double hyphen inside an XML comment;
           openbox rejects the whole file and silently loses every keybind. -->
    <keybind key="W-c">
      <action name="Execute">
        <command>env ELECTRON_DISABLE_SANDBOX=1 ELECTRON_NO_ASAR=1 /root/claude-app/bin/claude-desktop --no-sandbox</command>
        <startupnotify>
          <enabled>yes</enabled>
        </startupnotify>
      </action>
    </keybind>

    <!-- Ctrl+Alt+C: same as above. This is the binding to document for
         browser/noVNC users: host OSes swallow most Super-key combos
         (Win+key on Windows, Cmd+key on macOS) before noVNC sees them. -->
    <keybind key="C-A-c">
      <action name="Execute">
        <command>env ELECTRON_DISABLE_SANDBOX=1 ELECTRON_NO_ASAR=1 /root/claude-app/bin/claude-desktop --no-sandbox</command>
        <startupnotify>
          <enabled>yes</enabled>
        </startupnotify>
      </action>
    </keybind>

    <!-- F11: toggle fullscreen (handy if you want to compare states). -->
    <keybind key="F11">
      <action name="ToggleFullscreen"/>
    </keybind>

    <!-- Alt+F4: close focused window. -->
    <keybind key="A-F4">
      <action name="Close"/>
    </keybind>
  </keyboard>

  <applications>
    <!-- Claude's WM_CLASS is "Claude" (verified via xprop on a running
         instance). Tell openbox to drop window decorations and open it
         maximized so the kiosk feels like a single-app screen. -->
    <application class="Claude">
      <decor>no</decor>
      <maximized>true</maximized>
      <skip_taskbar>no</skip_taskbar>
    </application>
  </applications>
</openbox_config>
